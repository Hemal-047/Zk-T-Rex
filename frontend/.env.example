# Copy to .env.local for local dev, or paste into Vercel → Settings → Environment Variables.

# WalletConnect project ID (for RainbowKit WC support)
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=8f15d27cbe126b8608415d4a994d6b91

# Deployer private key used by /api/issue-credential and /api/revoke to
# sign on-chain transactions (mint hkBOND, update revocation root).
# 0x-prefixed 32-byte hex. MUST be the owner/agent of the deployed contracts.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# EdDSA issuer key (hex, 32 bytes, no 0x prefix). Must match the key the
# identity Merkle root was built against. See scripts/issuer-key.json.
ISSUER_PRIVATE_KEY=0001020304050607080900010203040506070809000102030405060708090001

# Admin API key for the /admin panel and /api/revoke endpoints.
# Pick any random string.
ADMIN_API_KEY=change-me-to-a-random-string
